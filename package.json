{
  "name": "localgem",
  "private": true,
  "version": "0.0.1",
  "description": "LocalGem – community-first local business directory",
  "scripts": {
    "prepare": "node .husky/install.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,css,json}\""
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "husky": "^9.1.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "prettier": "^3.4.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.15.0"
  },
  "engines": {
    "node": ">=20"
  }
}
